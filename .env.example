BOT_TOKEN=your_bot_token
BOT_USERNAME=your_bot_username
BOT_MODE=webhook

# Quick Vercel test mode (no external DB/Redis):
DATABASE_URL=sqlite+aiosqlite:////tmp/bonuska.db
REDIS_URL=

# For production replace with external services:
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DB_NAME
# REDIS_URL=redis://default:PASSWORD@HOST:6379/0

WEB_BASE_URL=https://your-project.vercel.app
WEBAPP_PATH=/webapp
WEBHOOK_BASE_URL=https://your-project.vercel.app
TELEGRAM_WEBHOOK_PATH=/api/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=your_random_secret
WEBHOOK_SETUP_TOKEN=your_random_setup_token
POSTBACK_PATH=/api/postback/event
POSTBACK_SECRET=

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
ADMIN_SESSION_SECRET=change_me_long_random_value
ADMIN_TG_ID=0

CHANNEL_URL=https://t.me/your_channel
REGISTRATION_URL=https://example.com/register
DEPOSIT_URL=https://example.com/deposit
INSTRUCTION_URL=https://example.com/instruction
INSTRUCTION_MESSAGE=📘 <b>How to use the bot</b>\n\n1) Register.\n2) Deposit.\n3) Follow funnel steps.
BONUS_CLAIM_URL=https://example.com/bonus
SIGNAL_URL=https://example.com/signal

SPIN_COOLDOWN_SECONDS=300
MAX_DAILY_SPINS_PER_USER=20
GLOBAL_WIN_RATE=0.35

REF_BONUS_L1=5
REF_BONUS_L2=4
REF_BONUS_L3=3
REF_BONUS_L4=2
REF_BONUS_L5=1
